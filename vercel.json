{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/((?!api/).*\\.[a-zA-Z0-9]+)",
      "dest": "client/$1"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "client/index.html"
    }
  ]
}
